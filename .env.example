# -----------------------------------------------------------------------------
# Production checklist (set in server .env, never commit real secrets)
#   APP_ENV=production  APP_DEBUG=false  APP_URL=https://your-domain
#   FORCE_HTTPS=true    SESSION_SECURE_COOKIE=true   LOG_LEVEL=error
#   Run: php artisan key:generate  migrate  config:cache  route:cache  view:cache
#   Queue worker if using database/redis queue: php artisan queue:work
# -----------------------------------------------------------------------------

APP_NAME="Virginia Cybercon"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Set true on HTTPS production so URL::asset() and route() use https://
FORCE_HTTPS=false

# Comma-separated IPs, or * for “trust X-Forwarded-* from any proxy” (typical behind load balancers).
# Tighten to 127.0.0.1 if only a local reverse proxy talks to PHP.
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=vacybercon
# DB_USERNAME=vacybercon_user
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
